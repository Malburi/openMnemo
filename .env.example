# ── Neo4j ──────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password

# ── MongoDB ────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=my_mcp

# ── SQL (SQLite 기본 / PostgreSQL 전환 가능) ────────
# SQLite (기본값 — 별도 설치 불필요)
SQL_URL=sqlite:///./my_mcp.db
# PostgreSQL 전환 시:
# SQL_URL=postgresql://user:pass@localhost:5432/my_mcp

# ── ChromaDB ───────────────────────────────────────
# 로컬 모드 (기본값 — 별도 서버 불필요)
CHROMA_MODE=local
CHROMA_PATH=./.chroma
# HTTP 서버 모드 전환 시:
# CHROMA_MODE=http
# CHROMA_HOST=localhost
# CHROMA_PORT=8000

# ── 임베딩 ─────────────────────────────────────────
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# local 모델 사용 시:
# EMBEDDING_PROVIDER=local
# LOCAL_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
