{
  "mcpServers": {
    "my-mcp": {
      "command": "C:\\Users\\사용자명\\openMnemo\\.venv\\Scripts\\python.exe",
      "args": ["-m", "openmnemo.mcp.server"],
      "cwd": "C:/Users/사용자명/openMnemo",
      "env": {
        "SQL_URL":        "sqlite:///./my_mcp.db",
        "CHROMA_PATH":    "./.chroma",
        "CHROMA_MODE":    "local",
        "NEO4J_URI":      "bolt://localhost:7687",
        "NEO4J_USER":     "neo4j",
        "NEO4J_PASSWORD": "여기에_Neo4j_비밀번호",
        "MONGO_URI":      "",
        "TENANT_ID":      "default"
      }
    }
  }
}
